# Gmail 발신 계정
GMAIL_USER=your_gmail@gmail.com

# Gmail 앱 비밀번호 (16자리, 공백 없이)
# 발급 방법: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# 수신자 이메일 (쉼표로 구분, 여러 명 가능)
RECIPIENT_EMAILS=recipient1@email.com,recipient2@email.com

# 조회 기간 (일 단위, 기본값=1 → 전날 이후 신규 항목만)
# 테스트 시에는 30 으로 설정하면 최근 30일치 데이터 수집
LOOKBACK_DAYS=1
